#include "FeatureDefines.xcconfig"
#include "../../../Configurations/Version.xcconfig"

FRAMEWORK_SEARCH_PATHS = "$(SDK_DIR)$(UMBRELLA_FRAMEWORKS_DIR)";

// On internal SDKs, try /System/Library/Frameworks first to work around rdar://134956870.
SYSTEM_FRAMEWORK_SEARCH_PATHS = $(SYSTEM_FRAMEWORK_SEARCH_PATHS_134956870_$(USE_INTERNAL_SDK)) $(inherited) $(WK_PRIVATE_SDK_DIR)$(SYSTEM_LIBRARY_DIR)/PrivateFrameworks;
SYSTEM_FRAMEWORK_SEARCH_PATHS_134956870_YES = $(SDK_DIR)$(SYSTEM_PREFIX)$(SYSTEM_LIBRARY_DIR)/Frameworks;

WK_FORMATREADERBUNDLE_CODESIGNING_DEFINES = ENABLE_LOWER_FORMATREADERBUNDLE_CODESIGNING_REQUIREMENTS;
WK_FORMATREADERBUNDLE_CODESIGNING_DEFINES[config=Production] = ;

WK_BUNDLE_VERSION_DEFINES = WEBKIT_BUNDLE_VERSION='"$(BUNDLE_VERSION)"';

ENABLE_LLVM_PROFILE_GENERATION_DEFINES = $(ENABLE_LLVM_PROFILE_GENERATION_DEFINES_$(ENABLE_LLVM_PROFILE_GENERATION));
ENABLE_LLVM_PROFILE_GENERATION_DEFINES_YES = ENABLE_LLVM_PROFILE_GENERATION=1;

GCC_PREFIX_HEADER = WebKit2Prefix.h;
GCC_PREPROCESSOR_DEFINITIONS = $(DEBUG_DEFINES) $(WK_CORE_PREDICTION_DEFINES) $(WK_FORMATREADERBUNDLE_CODESIGNING_DEFINES) $(ENABLE_PDFJS) $(ENABLE_LLVM_PROFILE_GENERATION_DEFINES) $(WK_BUNDLE_VERSION_DEFINES) $(WK_IS_PRODUCTION_BUILD_DEFINES) $(inherited) FRAMEWORK_NAME=WebKit;
SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) $(DEBUG_DEFINES);

ALTERNATE_HEADER_SEARCH_PATHS = $(ALTERNATE_HEADER_SEARCH_PATHS_$(SDK_VARIANT));
ALTERNATE_HEADER_SEARCH_PATHS_iosmac = $(BUILT_PRODUCTS_DIR)$(WK_ALTERNATE_FRAMEWORKS_DIR)$(WK_LIBRARY_HEADERS_FOLDER_PATH)

HEADER_SEARCH_PATHS = $(ALTERNATE_HEADER_SEARCH_PATHS) $(BUILT_PRODUCTS_DIR)$(WK_LIBRARY_HEADERS_FOLDER_PATH) "$(WEBCORE_PRIVATE_HEADERS_DIR)/ForwardingHeaders" $(BUILT_PRODUCTS_DIR)/DerivedSources/WebKit $(BUILT_PRODUCTS_DIR)/DerivedSources/WebKit/IPC $(WEBGPU_HEADER_SEARCH_PATHS) $(WEBKITADDITIONS_HEADER_SEARCH_PATHS) $(LIBWEBRTC_HEADER_SEARCH_PATHS) $(LIBWEBM_HEADER_SEARCH_PATHS) $(SRCROOT) $(HEADER_SEARCH_PATHS);
SYSTEM_HEADER_SEARCH_PATHS = $(WK_PRIVATE_SDK_DIR)$(WK_ALTERNATE_WEBKIT_SDK_PATH)$(WK_LIBRARY_HEADERS_FOLDER_PATH) $(inherited);

WK_OPTIMIZATION_PROFILE_FILE = $(BUILT_PRODUCTS_DIR)/DerivedSources/WebKit/WebKit.profdata;
WK_COMPRESSED_OPTIMIZATION_PROFILE_FILE = $(WK_COMPRESSED_OPTIMIZATION_PROFILE_FILE_$(USE_INTERNAL_SDK));
WK_COMPRESSED_OPTIMIZATION_PROFILE_FILE_YES = $(WK_WEBKITADDITIONS_HEADERS_FOLDER_PATH)/Profiling/WebKit.profdata.compressed;

WK_ENABLE_PGO_USE = $(WK_ENABLE_PGO_USE_$(WK_NOT_$(ENABLE_LLVM_PROFILE_GENERATION))_$(USE_INTERNAL_SDK)_$(CONFIGURATION)_$(WK_PLATFORM_NAME));
WK_ENABLE_PGO_USE_YES_YES_Release_macosx = YES;
WK_ENABLE_PGO_USE_YES_YES_Release_iphoneos = YES;
WK_ENABLE_PGO_USE_YES_YES_Release_xros = YES;
WK_ENABLE_PGO_USE_YES_YES_Production_macosx = YES;
WK_ENABLE_PGO_USE_YES_YES_Production_iphoneos = YES;
WK_ENABLE_PGO_USE_YES_YES_Production_xros = YES;

WK_PGO_USE_CFLAGS = $(WK_PGO_USE_CFLAGS_$(WK_ENABLE_PGO_USE));
WK_PGO_USE_CFLAGS_YES = -fprofile-use=$(WK_OPTIMIZATION_PROFILE_FILE) -Wno-error=backend-plugin;
WK_PGO_USE_LDFLAGS = $(WK_PGO_USE_LDFLAGS_$(WK_ENABLE_PGO_USE));
WK_PGO_USE_LDFLAGS_YES = -fprofile-use=$(WK_OPTIMIZATION_PROFILE_FILE) -Wno-error=backend-plugin;

// IR PGO profile generation flags
WK_PGO_GEN_FLAGS = $(WK_PGO_GEN_FLAGS_$(ENABLE_LLVM_PROFILE_GENERATION));
WK_PGO_GEN_FLAGS_YES = -fprofile-generate;

// Remove below workaround once fix from rdar://146134116 is universally available in all supported configurations.
LLVM_PROFILE_GENERATION_OTHER_LD_FLAGS = $(LLVM_PROFILE_GENERATION_OTHER_LD_FLAGS_$(ENABLE_LLVM_PROFILE_GENERATION))
LLVM_PROFILE_GENERATION_OTHER_LD_FLAGS_YES = -Wl,-dirty_data_list,/dev/null;

OTHER_LDFLAGS = $(inherited) $(LLVM_PROFILE_GENERATION_OTHER_LD_FLAGS) $(WK_PGO_USE_LDFLAGS) $(WK_PGO_GEN_FLAGS);
OTHER_CFLAGS = $(inherited) -iframework $(SDK_DIR)$(SYSTEM_LIBRARY_DIR)/PrivateFrameworks -D__STDC_WANT_LIB_EXT1__=1 $(WK_PGO_USE_CFLAGS) $(WK_PGO_GEN_FLAGS);

LD_ENVIRONMENT = $(inherited) $(LD_ENVIRONMENT_STAGED_FRAMEWORK_PATH_$(USE_STAGING_INSTALL_PATH));
LD_ENVIRONMENT_STAGED_FRAMEWORK_PATH_YES = DYLD_FRAMEWORK_PATH=$(WK_INSTALL_PATH_PREFIX)/System/Library/StagedFrameworks/Safari DYLD_LIBRARY_PATH=$(WK_INSTALL_PATH_PREFIX)/System/Library/StagedFrameworks/Safari;

// FIXME: There is no need for a variable that's always YES. If this ever needs to be disabled, it should be a USE, not a HAVE.
WK_HAVE_CORE_PREDICTION = YES;

WK_CORE_PREDICTION_DEFINES = $(WK_CORE_PREDICTION_DEFINES_$(WK_HAVE_CORE_PREDICTION));
WK_CORE_PREDICTION_DEFINES_YES = HAVE_CORE_PREDICTION;

WK_RELOCATABLE_WEBPUSHD = $(WK_AND_$(WK_RELOCATABLE_FRAMEWORKS)_$(WK_NOT_$(WK_EMPTY_$(WK_OVERRIDE_FRAMEWORKS_DIR))));
ENABLE_RELOCATABLE_WEBPUSHD = $(ENABLE_RELOCATABLE_WEBPUSHD_$(WK_RELOCATABLE_WEBPUSHD));
ENABLE_RELOCATABLE_WEBPUSHD_YES = ENABLE_RELOCATABLE_WEBPUSHD;

SWIFT_INCLUDE_PATHS = $(SRCROOT)/Modules/Internal;

HEADERMAP_INCLUDES_FRAMEWORK_ENTRIES_FOR_TARGETS_NOT_BEING_BUILT = NO;
HEADERMAP_USES_VFS = YES;
